# Anthropic API Key — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Vercel KV (Upstash Redis) — these are auto-injected when you attach a KV database in Vercel.
# For local dev, create a free Redis DB at https://upstash.com and paste the REST credentials here.
KV_REST_API_URL=https://YOUR_DATABASE.upstash.io
KV_REST_API_TOKEN=YOUR_TOKEN

# Amazon Associates affiliate tag (optional).
# Sign up at https://affiliate-program.amazon.com/
# When set, all Amazon links include ?tag=YOUR_TAG so you earn commission.
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=yourtag-20

# Brave Search API key (optional but recommended).
# Sign up at https://api-dashboard.search.brave.com/
# When set, each gift card is enriched with a real product image found via
# Brave Image Search. Results are cached in KV (no expiry), so a single search
# typically costs ~9 API calls the first time and 0 on repeat queries.
# Without this key the app still works, falling back to emoji-only cards.
BRAVE_API_KEY=YOUR_BRAVE_API_KEY

# Screenshotone API key — required for Pinterest pin image generation.
# Sign up free at https://screenshotone.com (free tier: 100 screenshots/month).
# Used by /api/pin to screenshot /pin-render/{slug} with a real Chrome instance,
# producing a JPEG that exactly matches the wizard's pin preview.
SCREENSHOTONE_ACCESS_KEY=YOUR_SCREENSHOTONE_KEY

# Production site URL — used by /api/pin to build the pin-render URL it sends
# to Screenshotone. On Vercel Pro/Team this is auto-set as
# VERCEL_PROJECT_PRODUCTION_URL. On Hobby or self-hosted, set this manually.
NEXT_PUBLIC_SITE_URL=https://lastminutegiftfinder.vercel.app

# Owner bypass token — long random secret (optional).
# When set, visiting /api/owner?token=THIS_VALUE in a browser sets a 1-year
# HttpOnly cookie that exempts that browser from the 5-searches-per-day rate
# limit. Use this so you (the site owner) can test freely without being
# capped. Generate with: openssl rand -hex 32
OWNER_BYPASS_TOKEN=YOUR_LONG_RANDOM_SECRET
